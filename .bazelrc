common --enable_bzlmod

# Bazel configuration for MCP Any

# build --config=remote

# Enable disk cache for fast incremental builds
build --disk_cache=~/.cache/bazel-disk-cache

# Enable Build without the Bytes for faster remote builds
build --remote_download_toplevel

# Show test output only on failure
test --test_output=errors

# Stream test output for debugging (use --config=verbose)
test:verbose --test_output=streamed

# Enable CGO for SQLite support
build --action_env=CGO_ENABLED=1

# Increase test timeout for integration tests
test --test_timeout=300,600,900,1800

# Allow all test sizes (default only runs small+medium)
test --test_size_filters=-enormous

# Enable sandboxing for hermeticity
build --spawn_strategy=sandboxed,local

# Use all available CPUs
# Pass through critical environment variables
test --test_env=GEMINI_API_KEY
test --test_env=MCP_BUNDLE_DIR
test --test_env=CI
test --test_env=HOME
test --test_env=MCPANY_DEBUG
test --test_env=MCPANY_DANGEROUS_ALLOW_LOCAL_IPS
test --test_env=PATH

# Also for actions if needed
build --action_env=GEMINI_API_KEY
build --action_env=MCP_BUNDLE_DIR
build --action_env=CI

common:nativelink --remote_cache=grpcs://nativelink-gprc.cubectl.com
# common:nativelink --remote_executor=grpcs://nativelink.cubectl.com
common:nativelink --remote_cache_compression
common:nativelink --jobs=100
build:nativelink --remote_timeout=10m
build:nativelink --spawn_strategy=remote

# Config for BuildBuddy specifically
build:buildbuddy --bes_results_url=https://buildbuddy.cubectl.com/invocation/
build:buildbuddy --bes_backend=grpcs://buildbuddy.cubectl.com
common:buildbuddy --remote_cache=grpcs://buildbuddy.cubectl.com
common:buildbuddy --remote_executor=grpcs://buildbuddy.cubectl.com
common:buildbuddy --spawn_strategy=remote
common:buildbuddy --genrule_strategy=remote
common:buildbuddy --remote_local_fallback
common:buildbuddy --remote_upload_local_results
common:buildbuddy --remote_cache_compression
common:buildbuddy --jobs=100
build:buildbuddy --remote_default_exec_properties=OSFamily=Linux
# build:buildbuddy --remote_default_exec_properties=Arch=arm64
build:buildbuddy --remote_timeout=10m
build:buildbuddy --verbose_failures

build:buildbuddy-official --bes_results_url=https://onehumancorp.buildbuddy.io/invocation/
build:buildbuddy-official --bes_backend=grpcs://onehumancorp.buildbuddy.io
common:buildbuddy-official --remote_cache=grpcs://onehumancorp.buildbuddy.io
common:buildbuddy-official --remote_upload_local_results
common:buildbuddy-official --remote_timeout=10m
common:buildbuddy-official --remote_executor=grpcs://onehumancorp.buildbuddy.io
common:buildbuddy-official --remote_cache_compression
common:buildbuddy-official --jobs=200
common:buildbuddy-official --remote_local_fallback

# Set buildbuddy as the default configuration for all builds
build:remote --config=buildbuddy-official

# Local config to disable remote execution
build:local --remote_cache=
build:local --remote_executor=
build:local --spawn_strategy=local
