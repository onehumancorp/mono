# Bazel configuration for MCP Any

build --config=remote
test --config=remote

# Enable disk cache for fast incremental builds
build --disk_cache=~/.cache/bazel-disk-cache

# Enable Build without the Bytes for faster remote builds.
# For tests under --config=remote we override this to download all outputs,
# because many test wrappers execute local helper binaries/scripts generated
# during the build phase.
build:remote --remote_download_all

# Show test output only on failure
test --test_output=errors
test --build_tests_only

# Stream test output for debugging (use --config=verbose)
test:verbose --test_output=streamed

# Enable CGO for SQLite support
build --action_env=CGO_ENABLED=1

# Increase test timeout for integration tests
test --test_timeout=300,600,900,1800

# Enable sandboxing for hermeticity
build --spawn_strategy=sandboxed,local

build --incompatible_strict_action_env
build --announce_rc

# Use all available CPUs
# Pass through critical environment variables
test --test_env=GEMINI_API_KEY
test --test_env=MINIMAX_API_KEY
test --test_env=MCP_BUNDLE_DIR
test --test_env=CI
test --test_env=HOME
test --test_env=MCPANY_DEBUG
test --test_env=MCPANY_DANGEROUS_ALLOW_LOCAL_IPS
test --test_env=PATH

# Also for actions if needed
build --action_env=GEMINI_API_KEY
build --action_env=MINIMAX_API_KEY
build --action_env=MCP_BUNDLE_DIR
build --action_env=CI

common:nativelink --remote_cache=grpcs://nativelink-gprc.cubectl.com
# common:nativelink --remote_executor=grpcs://nativelink.cubectl.com
common:nativelink --remote_cache_compression
common:nativelink --jobs=100
build:nativelink --remote_timeout=10m
build:nativelink --spawn_strategy=remote

# Config for BuildBuddy specifically
common:buildbuddy_remote-common --bes_results_url=https://buildbuddy.cubectl.com/invocation/
common:buildbuddy_remote-common --bes_backend=grpcs://buildbuddy-grpc.cubectl.com
common:buildbuddy_remote-common --remote_cache=grpcs://buildbuddy-grpc.cubectl.com
common:buildbuddy_remote-common --experimental_remote_downloader=grpcs://buildbuddy-grpc.cubectl.com
common:buildbuddy_remote-common --remote_executor=grpcs://buildbuddy-grpc.cubectl.com
common:buildbuddy_remote-common --spawn_strategy=remote
common:buildbuddy_remote-common --genrule_strategy=remote
common:buildbuddy_remote-common --remote_local_fallback
common:buildbuddy_remote-common --remote_upload_local_results
common:buildbuddy_remote-common --remote_cache_compression
common:buildbuddy_remote-common --jobs=200
build:buildbuddy_remote-common --remote_timeout=10m
build:buildbuddy_remote-common --verbose_failures
build:buildbuddy_remote-common --platforms=@toolchains_buildbuddy//platforms:linux_arm64
build:buildbuddy_remote-common --extra_execution_platforms=@toolchains_buildbuddy//platforms:linux_arm64
build:buildbuddy_remote-common --extra_toolchains=@toolchains_buildbuddy//toolchains/cc:ubuntu_gcc_arm64
# AMD64 Specifics
build:buildbuddy_remote-amd64 --config=_remote-base
build:buildbuddy_remote-amd64 --platforms=@toolchains_buildbuddy//platforms:linux_x86_64
build:buildbuddy_remote-amd64 --extra_execution_platforms=@toolchains_buildbuddy//platforms:linux_x86_64
build:buildbuddy_remote-amd64 --extra_toolchains=@toolchains_buildbuddy//toolchains/cc:ubuntu_gcc_x86_64
# ARM64 Specifics
build:buildbuddy_remote-arm64 --config=_remote-base
build:buildbuddy_remote-arm64 --platforms=@toolchains_buildbuddy//platforms:linux_arm64
build:buildbuddy_remote-arm64 --extra_execution_platforms=@toolchains_buildbuddy//platforms:linux_arm64
build:buildbuddy_remote-arm64 --extra_toolchains=@toolchains_buildbuddy//toolchains/cc:ubuntu_gcc_arm64

# --- THE MAGIC BIT ---
# This alias points to the specific config based on the host architecture
build:buildbuddy --define=executor=remote
build:buildbuddy --config=buildbuddy_remote-amd64
# If the host is arm64, the following line overrides the previous one
build:buildbuddy --config=buildbuddy_remote-arm64 --cpu=aarch64

build:buildbuddy-official --bes_results_url=https://onehumancorp.buildbuddy.io/invocation/
build:buildbuddy-official --bes_backend=grpcs://onehumancorp.buildbuddy.io
common:buildbuddy-official --remote_cache=grpcs://onehumancorp.buildbuddy.io
common:buildbuddy-official --remote_upload_local_results
common:buildbuddy-official --remote_timeout=10m
common:buildbuddy-official --remote_executor=grpcs://onehumancorp.buildbuddy.io
common:buildbuddy-official --remote_cache_compression
common:buildbuddy-official --jobs=200
common:buildbuddy-official --remote_local_fallback
# Default read-only key
common:buildbuddy-official --remote_header=x-buildbuddy-api-key=vGFjlQg7X49NwoQHAfRW

# Set buildbuddy as the default configuration for all builds
build:remote --config=buildbuddy-official
# Avoid local test host overload for targets that cannot run remotely
# (e.g. no-remote-exec Playwright/integration tests).
test:remote --local_test_jobs=8

# Local config to disable remote execution
build:local --remote_cache=
build:local --remote_executor=
build:local --spawn_strategy=local