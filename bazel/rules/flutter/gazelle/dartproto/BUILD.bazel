load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "dartproto",
    srcs = [
        "generate.go",
        "language.go",
        "resolve.go",
    ],
    importpath = "github.com/onehumancorp/mono/bazel/rules/flutter/gazelle/dartproto",
    visibility = ["//visibility:public"],
    deps = [
        "@gazelle//config",
