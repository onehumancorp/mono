        "@gazelle//language",
        "@gazelle//repo",
        "@gazelle//resolve",
        "@gazelle//rule",
        "@rules_flutter//flutter",
    ],
)

go_test(
    name = "dartproto_test",
    srcs = ["generate_test.go"],
    embed = [":dartproto"],
    deps = [
        "@gazelle//config",
        "@gazelle//language",
        "@gazelle//rule",
        "@rules_flutter//flutter",
    ],
)
