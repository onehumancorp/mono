    "pub_shared_preferences_android",
    "pub_shared_preferences_foundation",
    "pub_shared_preferences_linux",
    "pub_shared_preferences_platform_interface",
    "pub_shared_preferences_web",
    "pub_shared_preferences_windows",
    "pub_source_span",
    "pub_stack_trace",
    "pub_state_notifier",
    "pub_stream_channel",
    "pub_string_scanner",
    "pub_term_glyph",
    "pub_test_api",
    "pub_typed_data",
    "pub_uuid",
