# ── Flutter rules (vendored fork) ─────────────────────────────────────────────
bazel_dep(name = "rules_flutter", version = "0.0.0")
local_path_override(
    module_name = "rules_flutter",
    path = "bazel/rules/flutter",
)

flutter = use_extension("@rules_flutter//flutter:extensions.bzl", "flutter")
flutter.toolchain(flutter_version = "3.29.3")
use_repo(
    flutter,
    "flutter_sdk",
    "flutter_toolchains",
)

register_toolchains("@flutter_toolchains//:all")

pub = use_extension("@rules_flutter//flutter:extensions.bzl", "pub")
use_repo(
    pub,
    "pub_async",
    "pub_boolean_selector",
    "pub_centrifuge",
    "pub_characters",
    "pub_clock",
    "pub_collection",
    "pub_crypto",
    "pub_cupertino_icons",
    "pub_fake_async",
    "pub_ffi",
    "pub_file",
    "pub_fixnum",
    "pub_flutter_lints",
    "pub_flutter_riverpod",
    "pub_go_router",
    "pub_http",
    "pub_http_parser",
    "pub_intl",
    "pub_leak_tracker",
    "pub_leak_tracker_flutter_testing",
    "pub_leak_tracker_testing",
    "pub_lints",
    "pub_logging",
    "pub_matcher",
    "pub_material_color_utilities",
    "pub_meta",
    "pub_mocktail",
    "pub_path",
    "pub_path_provider_linux",
    "pub_path_provider_platform_interface",
    "pub_path_provider_windows",
    "pub_platform",
