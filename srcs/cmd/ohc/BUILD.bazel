load("@rules_go//go:def.bzl", "go_binary", "go_library", "go_test")

go_library(
    name = "ohc_lib",
    srcs = ["main.go"],
    importpath = "github.com/onehumancorp/mono/srcs/cmd/ohc",
    visibility = ["//visibility:private"],
    deps = [
        "//srcs/auth",
        "//srcs/billing",
        "//srcs/dashboard",
        "//srcs/domain",
        "//srcs/integrations/chatwoot",
        "//srcs/orchestration",
        "//srcs/telemetry",
        "@org_golang_google_grpc//:grpc",
    ],
)

go_binary(
    name = "ohc",
    embed = [":ohc_lib"],
    pure = "on",
    visibility = ["//visibility:public"],
)

go_test(
    name = "ohc_test",
    srcs = ["main_test.go"],
    embed = [":ohc_lib"],
)
