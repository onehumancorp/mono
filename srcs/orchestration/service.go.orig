	defer h.mu.Unlock()
	h.centrifugeNode = cn
}

// CentrifugeNode returns the currently attached CentrifugeNode (may be nil).
func (h *Hub) CentrifugeNode() *CentrifugeNode {
	h.mu.RLock()
