load("@rules_go//go:def.bzl", "go_library")
load("@rules_go//proto:def.bzl", "go_proto_library")
load("@rules_proto//proto:defs.bzl", "proto_library")

proto_library(
    name = "agentpb_proto",
    srcs = ["agent.proto"],
    visibility = ["//visibility:public"],
    deps = ["//srcs/proto/common:commonpb_proto"],
)

go_proto_library(
    name = "agentpb_go_proto",
    compilers = ["@rules_go//proto:go_grpc_v2"],
    importpath = "github.com/onehumancorp/mono/srcs/proto/agent",
    proto = ":agentpb_proto",
    visibility = ["//visibility:public"],
    deps = ["//srcs/proto/common"],
)

go_library(
    name = "agent",
    embed = [":agentpb_go_proto"],
    importpath = "github.com/onehumancorp/mono/srcs/proto/agent",
    visibility = ["//visibility:public"],
)
